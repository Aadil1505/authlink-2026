# SDM Backend — runs the CMAC validation
# Point this at your running sdm-backend instance
SDM_BACKEND_URL=http://127.0.0.1:5001

# NTAG-424 personalization server (nfc-pcsc, runs on a machine with a USB reader)
NTAG_PERSONALIZER_URL=http://localhost:3001

# App base URL — written into the NFC tag as the verification URL
BETTER_AUTH_URL=http://localhost:3000

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=CELsxhAryfqKGXmXuaTNyFMQDJhRGCYCKLRaE7oMUP3t

# "devnet" or "mainnet-beta" — used for Solana Explorer links
SOLANA_CLUSTER=devnet
