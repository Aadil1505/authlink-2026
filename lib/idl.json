  "types": [
    {
      "name": "ManufacturerRecord",
      "docs": [
        "One PDA per manufacturer, keyed by their Authlink DB user ID.",
        "Seeds: [b\"manufacturer\", manufacturer_id.as_bytes()]",
        "",
        "No per-tag accounts exist. Tag registrations are recorded as on-chain",
        "events (ProductRegistered / ProductRevoked) — cheap, permanent, verifiable."
      ],
